    "hranolky-firestore-common": "file:../common"
  },
  "devDependencies": {
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.46.4"
  },
  "private": true
}
